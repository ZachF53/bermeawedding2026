# ---------- Static & media -------------------------------------------
# Django collectstatic output (generated, never commit)
staticfiles/
collected_static/
# Project-root /static/ (we use wedding/static/ instead)
/static/
# wedding/static/ IS committed — those are source files / images / css / js
# Drop binary uploads from /media/ but keep folder placeholders
media/*.jpg
media/*.jpeg
media/*.png
media/*.gif
media/*.webp
media/*.svg
media/*.pdf
media/*.zip
!media/.gitkeep
!media/accommodations/.gitkeep
!media/couple/.gitkeep
!media/events/.gitkeep
!media/faq/.gitkeep
!media/story/.gitkeep

